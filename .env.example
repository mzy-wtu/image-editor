# 数据库配置 (mysql 或 sqlite)
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=image_editor
DB_USER=root
DB_PASSWORD=123456

# Flask配置
FLASK_ENV=production
SECRET_KEY=change-this-secret-key-in-production

# 图像存储路径
IMAGE_UPLOAD_FOLDER=./images
\n# CORS 白名单（多个地址用逗号分隔，不含空格）\nALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000
